# Example private Fluent Bit configuration.
#
# Copy to config/fluent-bit.local.conf, customize it, and set this in .env:
# FLUENT_BIT_CONFIG_PATH=./config/fluent-bit.local.conf
#
# The copied local file is ignored by Git. Do not place passwords, tokens, or
# private certificates in this example file.

@INCLUDE /fluent-bit/etc/fluent-bit.base.conf

# Add machine-specific filters or outputs below. For example, a later
# OpenSearch output can be configured here using environment variables or
# mounted secret files rather than committed credentials.
#
# [FILTER]
#     Name   modify
#     Match  *
#     Add    deployment.environment local

# TLS-protected syslog reception (RFC 5424, standard port 6514).
# Requires certificates generated by: make gen-tls-certs
# Set TLS_CERT_DIR in .env if your cert directory is not config/tls/.
#
# [INPUT]
#     Name               syslog
#     Mode               tcp
#     Listen             0.0.0.0
#     Port               6514
#     Parser             syslog-rfc5424
#     Tag                net.syslog.tls
#     Source_Address_Key net.src_ip
#     storage.type       filesystem
#     Mem_Buf_Limit      20M
#     tls                on
#     tls.verify         off
#     tls.cert_file      /fluent-bit/etc/tls/server.crt
#     tls.key_file       /fluent-bit/etc/tls/server.key
#
# Add the transport and enrichment filters for the TLS input:
#
# [FILTER]
#     Name    record_modifier
#     Match   net.syslog.tls
#     Record  net.transport  tcp+tls
#
# [FILTER]
#     Name         rewrite_tag
#     Match        net.syslog.tls
#     Rule         $host  \S+  net.syslog.tls          false
#     Rule         $log   .*   net.syslog.deadletter    false
#     Rule         $pri   .+   net.syslog.deadletter    false
#     Emitter_Name syslog_tls_router
#
# [FILTER]
#     Name    lua
#     Match   net.syslog.tls
#     script  /fluent-bit/etc/scripts/syslog_metadata.lua
#     call    enrich_syslog
#
# [FILTER]
#     Name    lua
#     Match   net.syslog.tls
#     script  /fluent-bit/etc/scripts/network_normalization.lua
#     call    normalize_network_event
#
# Local filters run after the included base configuration, so apply the
# canonical filter again after TLS source enrichment.
#
# [FILTER]
#     Name    lua
#     Match   net.syslog.tls
#     script  /fluent-bit/etc/scripts/canonical_normalization.lua
#     call    normalize_canonical_event

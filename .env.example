# Copy this file to .env and adjust it for the machine running the collector.
# The .env file is intentionally ignored by Git.

# Fluent Bit image to deploy.
FLUENT_BIT_IMAGE=fluent/fluent-bit:4.0

# Repository-relative configuration file mounted as the active collector config.
# To customize it privately:
#   cp config/fluent-bit.local.conf.example config/fluent-bit.local.conf
#   FLUENT_BIT_CONFIG_PATH=./config/fluent-bit.local.conf
FLUENT_BIT_CONFIG_PATH=./config/fluent-bit.conf

# Canonical metadata attached to every accepted event.
COLLECTOR_NAME=net-sec-watch-fluent-bit
SITE_NAME=default
DEPLOYMENT_ENVIRONMENT=development

# Development OpenSearch node. The API binds only to localhost and the
# development profile intentionally disables the Security plugin.
OPENSEARCH_IMAGE=opensearchproject/opensearch:3.7.0
OPENSEARCH_HTTP_BIND=127.0.0.1
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# OpenSearch Dashboards browser interface. Keep this bound to localhost until
# Phase 6 configures browser TLS and centralized authentication.
OPENSEARCH_DASHBOARDS_IMAGE=opensearchproject/opensearch-dashboards:3.7.0
OPENSEARCH_DASHBOARDS_BIND=127.0.0.1
OPENSEARCH_DASHBOARDS_PORT=5601

# Secure development ingestion. Leave the password empty in this committed
# example; make init generates a strong value in the ignored .env file.
OPENSEARCH_USERNAME=admin
OPENSEARCH_INITIAL_ADMIN_PASSWORD=

# Host paths containing Linux and Docker logs. Demo paths keep the project safe
# to start without granting access to real host logs.
HOST_LOG_ROOT=./examples/logs/system
CONTAINER_LOG_ROOT=./examples/logs/containers

# Bind the Fluent Bit health and metrics API to localhost by default.
FLUENT_BIT_HTTP_BIND=127.0.0.1
FLUENT_BIT_HTTP_PORT=2020

# Syslog receiver ports. SYSLOG_BIND controls which host interface listens.
# Standard ports (514/514/6514) require no firewall exceptions on most Linux hosts.
# On Windows/WSL2 use the port forwarding procedure in docs/phase-2-network-syslog.md.
SYSLOG_BIND=0.0.0.0
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514
SYSLOG_TLS_PORT=6514

# Directory containing TLS certificates for the syslog TLS input.
# Generate with: make gen-tls-certs
# Only needed when fluent-bit.local.conf has the TLS INPUT block enabled.
TLS_CERT_DIR=./config/tls

# Optional Zeek network-metadata sensor. Start with: make up-zeek
# The interface must receive mirrored, tapped, or gateway traffic.
ZEEK_IMAGE=zeek/zeek:lts
ZEEK_INTERFACE=eth0
ZEEK_LOG_VOLUME=zeek-logs

# Optional passive Suricata IDS and flow sensor. Start with: make up-suricata
SURICATA_IMAGE=jasonish/suricata:8.0.5
SURICATA_INTERFACE=eth0
SURICATA_LOG_VOLUME=suricata-logs

# Open-source software inventory and vulnerability-audit images.
SYFT_IMAGE=anchore/syft:v1.45.1
GRYPE_IMAGE=anchore/grype:v0.114.0

# Container image included in the runtime security audit.
AUDIT_TARGET_IMAGE=fluent/fluent-bit:4.0

# Optional Grype enforcement threshold: negligible, low, medium, high, or
# critical. Leave empty to generate evidence without failing the audit command.
AUDIT_FAIL_ON=
